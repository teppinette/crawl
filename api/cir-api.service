[Unit]
Description=COPAP CIR Research API
After=network-online.target
Wants=network-online.target
# After 5 failed starts in 60s, stop looping and enter `failed` (loud, terminal)
# instead of an infinite silent `activating (auto-restart)` loop.
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
WorkingDirectory=/home/copapadmin/crawl/api
# Reap any stale/orphaned process holding 8400 before binding (e.g. a worker
# left over from an unclean shutdown). `-` ignores exit code when port is free.
ExecStartPre=-/usr/bin/fuser -k 8400/tcp
ExecStart=/home/copapadmin/claude/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8400 --workers 4
Restart=always
RestartSec=5
# API key (cir-api-key) is read from Azure Key Vault via managed identity at
# main.py:66 (get_secret). NOT set here — vault is the single source of truth.
Environment=PATH=/home/copapadmin/claude/venv/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target
