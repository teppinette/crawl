+        }
+        if country_code in crawl_allowlist:
+            if not self._settings.crawl_verify_api_key:
+                logger.warning(
+                    "CRAWL_VERIFY_API_KEY not set -- %s falls back to legacy adapter",
+                    country_code,
+                )
+            else:
+                client = CrawlVerifyClient(
+                    country_code=country_code,
+                    base_url=self._settings.crawl_verify_base_url,
+                    api_key=self._settings.crawl_verify_api_key,
+                )
+                logger.info("Routing %s through Crawl Verify Gateway", country_code)
+                self._clients[country_code] = client
+                return client
