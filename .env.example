# OpenClaw OSINT Platform -- Environment Variables
# NEVER commit real values. Copy to .env and fill in.
# These are for the COPAPCrawl subscription ONLY -- no production keys.

# Azure (COPAPCrawl subscription)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-crawl-osint
AZURE_STORAGE_ACCOUNT=stcrawlosint
AZURE_STORAGE_CONTAINER=osint-staging

# COPAP VPN public IP (for NSG SSH lockdown)
COPAP_VPN_PUBLIC_IP=

# LLM API Keys (separate from production)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
SARVAM_API_KEY=

# SwarmClaw
SWARMCLAW_PORT=3456

# VM SSH key path
SSH_KEY_PATH=~/.ssh/crawl_rsa

# Production DB (READ-ONLY -- used by seed_entities.py on dev machine only)
# This is NEVER deployed to OpenClaw VMs
SEED_SQL_SERVER=172.20.0.6
SEED_SQL_USERNAME=copapadmin
SEED_SQL_PASSWORD=
